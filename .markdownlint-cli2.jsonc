{
  // Relaxed, readable markdown — prose-first repo, not a docs site.
  "config": {
    "default": true,
    "MD013": false, // no hard line-length limit
    "MD033": false, // allow inline HTML (badges, <div align>)
    "MD041": false, // first line need not be a top-level heading (HTML hero blocks)
    "MD024": { "siblings_only": true } // repeated headings ok across sections
  },
  "globs": ["**/*.md"],
  "ignores": ["node_modules", "board/public", "board/vendor"]
}
