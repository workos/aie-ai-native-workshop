{
  "name": "aie-glossary",
  "version": "1.0.0",
  "private": true,
  "description": "The AI-Native Glossary — a static Vite/React glossary + ask-anything chat, served by a Cloudflare Worker.",
  "type": "module",
  "scripts": {
    "dev": "vite",
